---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Agent Hunter - AI Agent 商业案例库" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Agent Hunter</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#fcfcfc] text-slate-900 font-sans min-h-screen flex flex-col selection:bg-orange-100 selection:text-orange-900">
    <header class="bg-white/80 backdrop-blur-xl sticky top-0 z-50 border-b border-slate-100 shadow-[0_2px_15px_-3px_rgba(0,0,0,0.03)]">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-orange-500 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-orange-200 group-hover:rotate-6 transition-all">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-slate-900 tracking-tight">Agent Hunter</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="text-slate-600 hover:text-orange-600 font-medium transition-colors">概览</a>
          <a href="#" class="text-slate-600 hover:text-orange-600 font-medium transition-colors">计算机</a>
          <a href="#" class="text-slate-600 hover:text-orange-600 font-medium transition-colors">金字塔</a>
          <a href="https://github.com/vibe-coding/agent-hunter" target="_blank" class="bg-slate-900 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-slate-800 transition-all shadow-md active:scale-95">
            加入社区
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-white border-t border-slate-100 py-12 mt-20">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="flex items-center gap-4">
           <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400">AH</div>
           <p class="text-slate-400 text-sm">© {new Date().getFullYear()} Agent Hunter. 助力 AI 自动化变现。</p>
        </div>
        <div class="flex gap-6">
          <a href="#" class="text-slate-400 hover:text-orange-500 transition-colors">关于我们</a>
          <a href="#" class="text-slate-400 hover:text-orange-500 transition-colors">数据规范</a>
          <a href="#" class="text-slate-400 hover:text-orange-500 transition-colors">贡献指南</a>
        </div>
      </div>
    </footer>
  </body>
</html>
