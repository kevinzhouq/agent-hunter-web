---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const agents = await getCollection('agents');
  return agents.map(agent => ({
    params: { slug: agent.id },
    props: { agent },
  }));
}

const { agent } = Astro.props;
const { Content } = await render(agent);

const canvas = agent.data.canvas;

const LEVEL_NAMES = ['L1 定制开发', 'L2 服务打包', 'L3 垂直应用', 'L4 订阅会员', 'L5 生态变现', 'L6 内容流量'];
const currentLevelStr = agent.data.level || ""; 
const match = currentLevelStr.match(/L(\d)/);
const currentLevelNum = match ? parseInt(match[1]) : 0;
---

<BaseLayout title={`${agent.data.title} | 案例看板`}>
  <div class="max-w-6xl mx-auto px-6 pt-12 pb-32">
    <!-- Breadcrumb & Title -->
    <nav class="mb-10 flex items-center gap-2 text-sm">
      <a href="/" class="text-slate-400 hover:text-orange-500 transition-colors">所有项目</a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-900 font-medium">案例看板</span>
    </nav>

    <!-- Header Stats Panel -->
    <div class="bg-white rounded-3xl border border-slate-100 p-8 md:p-10 shadow-sm mb-12">
      <!-- Title Section -->
      <div class="mb-10 lg:pr-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-50 text-orange-600 text-[10px] font-bold uppercase tracking-widest mb-4">
          🔥 深度解析中
        </div>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">{agent.data.title}</h1>
        <p class="text-lg text-slate-500 max-w-2xl leading-relaxed">{agent.data.summary}</p>

        <!-- Level Progress Bar -->
        <!-- Level Progress Bar -->
        <div class="flex flex-wrap gap-2 mt-6">
          {LEVEL_NAMES.map((name, index) => {
            const levelNum = index + 1; // 1 到 6
            
            // 状态判定
            const isActive = levelNum === currentLevelNum;
            const isPassed = levelNum < currentLevelNum;
            
            // 动态 Class
            let colorClass = "bg-gray-100 text-gray-400"; // 默认锁定态
            if (isActive) colorClass = "bg-orange-500 text-white font-bold shadow-md";
            else if (isPassed) colorClass = "bg-orange-100 text-orange-500";
            
            return (
              <span class={`px-3 py-1 text-xs rounded-full ${colorClass} font-medium`}>
                {name}
              </span>
            );
          })}
        </div>
        
        <!-- Metadata Tags -->
        {agent.data.metadata && (
          <div class="flex flex-wrap gap-4 mt-6">
            {agent.data.metadata.founder && (
               <div class="bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg text-sm flex items-center gap-2">
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                 {agent.data.metadata.founder}
               </div>
            )}
            {agent.data.metadata.team_size && (
               <div class="bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg text-sm flex items-center gap-2">
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                 {agent.data.metadata.team_size}
               </div>
            )}
            {agent.data.metadata.location && (
               <div class="bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg text-sm flex items-center gap-2">
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                 {agent.data.metadata.location}
               </div>
            )}
            {agent.data.metadata.funding && (
               <div class="bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg text-sm flex items-center gap-2">
                 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                 {agent.data.metadata.funding}
               </div>
            )}
          </div>
        )}
      </div>

      <!-- Stats & Radar Two-columns -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        
        <!-- Left Column: Scores -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-slate-50 rounded-3xl p-6 hover:bg-slate-100 transition-colors">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest block mb-2">Leverage</span>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-black text-slate-900 font-mono tracking-tight">{agent.data.leverage}</span>
              <span class="text-slate-400 font-bold text-sm">/10</span>
            </div>
          </div>
          <div class="bg-slate-50 rounded-3xl p-6 hover:bg-slate-100 transition-colors">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest block mb-2">Execution</span>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-black text-slate-900 font-mono tracking-tight">{agent.data.execution}</span>
              <span class="text-slate-400 font-bold text-sm">/10</span>
            </div>
          </div>
          <div class="bg-slate-50 rounded-3xl p-6 hover:bg-slate-100 transition-colors">
            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest block mb-2">ROI</span>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-black text-slate-900 font-mono tracking-tight">{agent.data.roi}</span>
              <span class="text-slate-400 font-bold text-sm">/10</span>
            </div>
          </div>
          <div class="bg-orange-500 rounded-3xl p-6 text-white shadow-xl shadow-orange-500/20">
            <span class="text-[11px] font-bold text-orange-200 uppercase tracking-widest block mb-2">Total Score</span>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-black font-mono tracking-tight">{agent.data.total}</span>
              <span class="text-orange-200 font-bold text-sm"> pts</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Radar Chart -->
        <div class="bg-[#fafafa] rounded-3xl border border-slate-100 p-6 flex flex-col justify-center">
          <h3 class="text-sm font-bold text-slate-800 mb-2 text-center tracking-wide">能力多边形</h3>
          <div id="radar-chart" class="w-full h-64 md:h-72"></div>
        </div>
      </div>
    </div>

    <!-- Business Model Canvas (Bento Grid Waterfall) -->
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1.5 h-6 bg-orange-500 rounded-full"></div>
        <h2 class="text-2xl font-black text-slate-900 tracking-tight">商业画布 9 宫格</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- 第一列 -->
        <div class="flex flex-col gap-6">
          <!-- 关键合作伙伴 -->
          <div class="bg-blue-50/50 border border-blue-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">🔗 关键合作伙伴</h3>
            {Array.isArray(canvas.partners) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.partners.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.partners}</p>
            )}
          </div>

          <!-- 价值主张 -->
          <div class="bg-orange-50/50 border border-orange-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">💎 价值主张</h3>
            {Array.isArray(canvas.value_prop) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.value_prop.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.value_prop}</p>
            )}
          </div>

          <!-- 收入来源 -->
          <div class="bg-green-50/50 border border-green-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">💰 收入来源</h3>
            {Array.isArray(canvas.revenues) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.revenues.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.revenues}</p>
            )}
          </div>
        </div>

        <!-- 第二列 -->
        <div class="flex flex-col gap-6">
          <!-- 关键活动 -->
          <div class="bg-green-50/50 border border-green-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">⚡ 关键活动</h3>
            {Array.isArray(canvas.activities) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.activities.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.activities}</p>
            )}
          </div>

          <!-- 客户关系 -->
          <div class="bg-yellow-50/50 border border-yellow-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">🤝 客户关系</h3>
            {Array.isArray(canvas.relationships) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.relationships.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.relationships}</p>
            )}
          </div>

          <!-- 客户细分 -->
          <div class="bg-blue-50/50 border border-blue-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">🎯 客户细分</h3>
            {Array.isArray(canvas.segments) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.segments.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.segments}</p>
            )}
          </div>
        </div>

        <!-- 第三列 -->
        <div class="flex flex-col gap-6">
          <!-- 核心资源 -->
          <div class="bg-purple-50/50 border border-purple-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">🛠️ 核心资源</h3>
            {Array.isArray(canvas.resources) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.resources.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.resources}</p>
            )}
          </div>

          <!-- 分发渠道 -->
          <div class="bg-rose-50/50 border border-rose-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">🚀 分发渠道</h3>
            {Array.isArray(canvas.channels) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.channels.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.channels}</p>
            )}
          </div>

          <!-- 成本结构 -->
          <div class="bg-rose-50/50 border border-rose-100 rounded-2xl p-6 text-sm">
            <h3 class="text-gray-800 font-semibold mb-3 flex items-center gap-2">💸 成本结构</h3>
            {Array.isArray(canvas.costs) ? (
              <ul class="list-disc list-inside marker:text-orange-500 space-y-2 text-gray-600">
                {canvas.costs.map(item => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="text-gray-600 leading-relaxed">{canvas.costs}</p>
            )}
          </div>
        </div>

      </div>
    </div>

    <!-- Vulnerability Board -->
    {agent.data.vulnerabilities && agent.data.vulnerabilities.length > 0 && (
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1.5 h-6 bg-red-500 rounded-full"></div>
          <h2 class="text-2xl font-black text-slate-900 tracking-tight">🛡️ 脆弱性测试 (Stress Test)</h2>
        </div>
        <div class="flex flex-col gap-4">
          {agent.data.vulnerabilities.map(vuln => {
            let borderColor = "border-emerald-500";
            let tagBg = "bg-emerald-100 text-emerald-600";
            if (vuln.level === '高' || vuln.level === '极高') {
              borderColor = "border-red-500";
              tagBg = "bg-red-100 text-red-600";
            } else if (vuln.level === '中') {
              borderColor = "border-orange-500";
              tagBg = "bg-orange-100 text-orange-600";
            }
            
            return (
              <div class={`bg-white rounded-2xl border-l-4 ${borderColor} p-6 shadow-sm flex flex-col md:flex-row gap-6 md:items-center justify-between`}>
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-2">
                    <span class={`px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-wider ${tagBg}`}>
                      {vuln.level}风险
                    </span>
                    <h3 class="text-lg font-bold text-slate-800">{vuln.risk}</h3>
                  </div>
                  <p class="text-slate-500 text-sm">
                    应对策略：<span class="text-slate-700 font-medium">{vuln.strategy}</span>
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Detail Reading Area (Markdown) -->
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-1.5 h-6 bg-slate-900 rounded-full"></div>
        <h2 class="text-2xl font-black text-slate-900 tracking-tight">深度解剖报告</h2>
      </div>

      <div class="bg-white rounded-3xl border border-slate-100 p-8 md:p-16 shadow-sm">
        <div class="prose prose-slate prose-lg max-w-none 
          prose-headings:text-slate-900 prose-headings:font-bold prose-headings:tracking-tight
          prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:border-b prose-h2:border-slate-50 prose-h2:pb-4
          prose-blockquote:italic prose-blockquote:text-slate-500 prose-blockquote:border-l-orange-500 prose-blockquote:bg-orange-50/30 prose-blockquote:py-2 prose-blockquote:pr-4 prose-blockquote:rounded-r-xl
          prose-strong:text-slate-900 prose-strong:font-bold
          prose-a:text-orange-500 hover:prose-a:text-orange-600 transition-colors">
          <Content />
        </div>
      </div>
    </div>

    <div class="mt-20 flex justify-center">
       <a href="/" class="px-10 py-4 bg-slate-900 text-white font-bold rounded-2xl hover:bg-slate-800 transition-all shadow-xl active:scale-95">
          返回案例发现
       </a>
    </div>
  </div>

  <!-- ECharts 引入与渲染逻辑 -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
  <script is:inline define:vars={{ radarData: agent.data.radar }}>
    document.addEventListener('DOMContentLoaded', () => {
      const chartDom = document.getElementById('radar-chart');
      if (!chartDom) return;
      
      const myChart = echarts.init(chartDom);
      const option = {
        radar: {
          indicator: [
            { name: '技术复杂度', max: 10 },
            { name: '市场契合度', max: 10 },
            { name: '变现确定性', max: 10 },
            { name: '团队要求', max: 10 },
            { name: '规模化潜力', max: 10 },
            { name: '可持续性', max: 10 }
          ],
          splitNumber: 4,
          axisName: {
            color: '#64748b', // text-slate-500
            fontSize: 10,
            fontWeight: 600
          },
          splitArea: { show: false }, // 去除背景区域
          axisLine: {
            lineStyle: { color: '#e2e8f0' } // text-slate-200
          },
          splitLine: {
            lineStyle: { color: '#f1f5f9' } // text-slate-100
          }
        },
        series: [
          {
            type: 'radar',
            data: [
              {
                value: radarData,
                name: '能力多边形',
                itemStyle: {
                  color: '#f97316' // text-orange-500
                },
                areaStyle: {
                  color: 'rgba(249, 115, 22, 0.2)' // 浅橙色透明填充
                },
                lineStyle: {
                  width: 2,
                  color: '#f97316'
                },
                symbol: 'circle',
                symbolSize: 6
              }
            ]
          }
        ]
      };
      
      myChart.setOption(option);
      
      // 响应式 Resize
      window.addEventListener('resize', () => {
        myChart.resize();
      });
    });
  </script>
</BaseLayout>
