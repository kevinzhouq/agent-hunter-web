---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import AgentCard from '../components/AgentCard.astro';

import Hero from '../components/Hero.astro';

const communityDevs = "1,200+";

// 获取并通过日期倒序排列
const allAgents = await getCollection('agents');
const sortedAgents = allAgents.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// 数据计算
const totalCases = allAgents.length;
const avgScore = totalCases > 0 
  ? (allAgents.reduce((acc, curr) => acc + curr.data.total, 0) / totalCases).toFixed(1)
  : 0;
const avgRoi = totalCases > 0
  ? (allAgents.reduce((acc, curr) => acc + curr.data.roi, 0) / totalCases).toFixed(1)
  : 0;
---

<BaseLayout title="Agent Hunter 生态解剖">
  <Hero />

  <!-- Stats Grid -->
  <section class="max-w-6xl mx-auto px-6 mb-24">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <StatCard 
        label="成功案例" 
        value={totalCases} 
        unit="个" 
      />
      <StatCard 
        label="平均综合评分" 
        value={avgScore} 
        unit="分"
        icon='<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-1.724 1.44-1.902.8l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-2.204-.12-1.902-.8l1.518-4.674a1 1 0 00-.363-1.118L2.98 10.1c-.783-.57-.381-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>' 
      />
      <StatCard 
        label="平均 ROI" 
        value={avgRoi} 
        unit="倍" 
        icon='<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
      />
      <StatCard 
        label="社区开发者" 
        value={communityDevs} 
        unit="" 
        icon='<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>'
      />
    </div>
  </section>

  <!-- Agents Section -->
  <section id="cases" class="max-w-6xl mx-auto px-6 pb-32">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 mb-2 tracking-tight">案例深度解剖</h2>
        <p class="text-slate-400">最新收录的 AI 自动化实战案例</p>
      </div>
      <div class="flex gap-2">
        <button class="bg-white border border-slate-100 p-2 rounded-xl shadow-sm hover:text-orange-500 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4.5h18m-18 3h18m-18 3h18m-18 3h18"/></svg>
        </button>
      </div>
    </div>

    <div class="flex flex-col">
      {sortedAgents.map((agent) => (
        <AgentCard 
          href={`/agent/${agent.id}`}
          title={agent.data.title}
          summary={agent.data.summary}
          leverage={agent.data.leverage}
          execution={agent.data.execution}
          roi={agent.data.roi}
        />
      ))}
    </div>
  </section>
</BaseLayout>
