---
interface Props {
  label: string;
  value: string | number;
  unit?: string;
  icon?: string;
}

const { label, value, unit = "", icon } = Astro.props;
---

<div class="bg-white rounded-2xl border border-slate-100 p-6 flex items-start gap-4 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.02)] hover:shadow-md transition-all">
  <div class="w-10 h-10 rounded-xl bg-orange-50 flex items-center justify-center text-orange-500 flex-shrink-0">
    {icon ? (
      <Fragment set:html={icon} />
    ) : (
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
      </svg>
    )}
  </div>
  <div>
    <h3 class="text-slate-400 text-sm font-medium mb-1">{label}</h3>
    <div class="flex items-baseline gap-1">
      <span class="text-3xl font-bold text-orange-500 tracking-tight">{value}</span>
      <span class="text-orange-900/40 text-sm font-semibold">{unit}</span>
    </div>
  </div>
</div>
