---
---

<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden px-4">
  <!-- 氛围背景（浅橙色渐变光晕点缀） -->
  <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-orange-200/20 rounded-full blur-3xl opacity-50 -z-10 animate-pulse mix-blend-multiply"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[300px] h-[300px] bg-slate-200/30 rounded-full blur-3xl opacity-50 -z-10 mix-blend-multiply"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-orange-50/40 rounded-full blur-[100px] -z-20"></div>

  <div class="max-w-4xl mx-auto flex flex-col items-center text-center relative z-10">
    <!-- 预热标签 (Pill) -->
    <div class="inline-flex items-center gap-1.5 bg-orange-50 text-orange-500 rounded-full px-4 py-1 text-sm font-medium border border-orange-100/50 shadow-sm">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" />
      </svg>
      Agent Hunter 研究计划
    </div>

    <!-- 超大主标题 -->
    <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 tracking-tight mt-6 leading-tight">
      Agent Hunter 生态解剖
    </h1>

    <!-- 副标题 -->
    <p class="text-lg md:text-xl text-gray-500 mt-4 max-w-2xl mx-auto leading-relaxed tracking-wide">
      深度解析 AI 自动化变现的六大成功案例，揭示从代码到收入的完整路径
    </p>

    <!-- CTA 按钮 -->
    <a href="#cases" class="inline-flex items-center gap-2 bg-orange-500 text-white rounded-full px-8 py-3.5 mt-8 hover:bg-orange-600 transition-all shadow-lg shadow-orange-500/30 active:scale-95 font-medium text-lg group">
      立即开始探索 
      <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7-7 7M3 12h18" />
      </svg>
    </a>
  </div>
</section>
